{
  "name": "isha-intelli-contractor-ops",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "cd services/api && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev:mobile": "cd apps/mobile && npx expo start",
    "install:all": "npm install --workspaces"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
